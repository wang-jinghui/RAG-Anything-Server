# RAG-Anything Server Configuration

# ===========================================
# Server Settings
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/raganything
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# JWT Authentication (CHANGE IN PRODUCTION!)
# ===========================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key Settings
API_KEY_PREFIX=rak_

# ===========================================
# CORS & Security
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=50

# ===========================================
# LLM Configuration
# ===========================================
# Provider: openai, azure, vllm, lmstudio, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Azure OpenAI (optional - uncomment if using Azure)
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_LLM_DEPLOYMENT=your-deployment-name
# AZURE_API_VERSION=2024-02-15-preview

# LM Studio (local)
# LLM_PROVIDER=lmstudio
# OPENAI_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# OPENAI_API_KEY=not-needed

# Ollama (local)
# LLM_PROVIDER=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama2

# vLLM (self-hosted)
# LLM_PROVIDER=vllm
# OPENAI_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=meta-llama/Llama-2-7b-chat-hf

# ===========================================
# Embedding Model Configuration
# ===========================================
# Provider: openai, azure, ollama, huggingface
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_BATCH_SIZE=32

# Alternative embedding providers
# Ollama: EMBEDDING_PROVIDER=ollama, EMBEDDING_MODEL=nomic-embed-text
# HuggingFace: EMBEDDING_PROVIDER=huggingface, EMBEDDING_MODEL=BAAI/bge-m3

# ===========================================
# Ranking Model (Optional - for re-ranking)
# ===========================================
RANK_ENABLED=false
RANK_MODEL_NAME=BAAI/bge-m3
RANK_TOP_K=10

# ===========================================
# Vector Storage Configuration
# ===========================================
# Type: pgvector, milvus, qdrant, chroma
VECTOR_STORAGE_TYPE=pgvector

# PostgreSQL/PGVector settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=raganything

# Milvus (optional)
# VECTOR_STORAGE_TYPE=milvus
# MILVUS_URI=./milvus_local.db

# Qdrant (optional)
# VECTOR_STORAGE_TYPE=qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-api-key

# Chroma (optional - good for development)
# VECTOR_STORAGE_TYPE=chroma
# CHROMA_PATH=./chroma_db

# ===========================================
# Graph Storage Configuration (Knowledge Graph)
# ===========================================
# Type: neo4j, age
GRAPH_STORAGE_TYPE=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Apache AGE (optional - uses PostgreSQL)
# GRAPH_STORAGE_TYPE=age
# AGE_POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/raganything

# ===========================================
# RAG Processing Configuration
# ===========================================
RAG_WORKING_DIR=./rag_storage
CHUNK_TOKEN_SIZE=1200
CHUNK_OVERLAP_TOKEN_SIZE=100
DEFAULT_QUERY_MODE=hybrid
DEFAULT_TOP_K=10

# ===========================================
# Document Parser Configuration
# ===========================================
# Parser: mineru (default), docling, paddleocr
PARSER_METHOD=mineru
ENABLE_IMAGE_PROCESSING=true
ENABLE_OCR=true

# MinerU specific
MINERU_CONFIG=default

# PaddleOCR (if using OCR)
# PADDLEOCR_LANG=en
# PADDLEOCR_USE_GPU=false

# ===========================================
# Logging & Monitoring
# ===========================================
LOG_LEVEL=INFO
RAG_LOG_LEVEL=INFO

